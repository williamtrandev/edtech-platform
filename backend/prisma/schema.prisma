generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

enum UserRole {
  USER
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  LOCKED
}

enum LessonContentType {
  VIDEO
  TEXT
  RESOURCE
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  FREE_TEXT
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssignmentSubmissionStatus {
  SUBMITTED
  GRADED
}

enum NotificationType {
  ENROLLMENT_SUCCESS
  ASSIGNMENT_GRADED
  CERTIFICATE_ISSUED
  COURSE_PUBLISHED
  SYSTEM
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

model User {
  id        String     @id
  email     String     @unique
  role      UserRole   @default(USER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  createdCourses         Course[]                @relation("CourseInstructor")
  lockedCourses          Course[]                @relation("CourseLockedBy")
  enrollments            Enrollment[]
  lessonProgress         LessonProgress[]
  auditLogs              AuditLog[]              @relation("AuditActor")
  courseReviews          CourseReview[]
  examAttempts           ExamAttempt[]
  assignmentSubmissions  AssignmentSubmission[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  certificates           Certificate[]
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  inAppEnabled      Boolean  @default(true)
  emailEnabled      Boolean  @default(false)
  enrollmentSuccess Boolean  @default(true)
  assignmentGraded  Boolean  @default(true)
  certificateIssued Boolean  @default(true)
  coursePublished   Boolean  @default(true)
  system            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id               String            @id @default(cuid())
  userId           String
  courseId         String
  verificationCode String            @unique
  status           CertificateStatus @default(ACTIVE)
  issuedAt         DateTime          @default(now())
  revokedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model Course {
  id              String       @id @default(cuid())
  title           String
  description     String?
  category        String?
  level           String?
  language        String?
  durationMinutes Int?
  requirements    String?
  outcomes        String?
  coverImageUrl   String?
  ratingAverage   Float        @default(0)
  ratingCount     Int          @default(0)
  status          CourseStatus @default(DRAFT)
  instructorId    String
  lockReason      String?
  lockedAt        DateTime?
  lockedById      String?
  statusBeforeLock CourseStatus?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  archivedAt      DateTime?

  instructor   User           @relation("CourseInstructor", fields: [instructorId], references: [id])
  lockedBy     User?          @relation("CourseLockedBy", fields: [lockedById], references: [id])
  lessons      Lesson[]
  exams        Exam[]
  enrollments  Enrollment[]
  reviews      CourseReview[]
  assignments  Assignment[]
  certificates Certificate[]

  @@index([status])
  @@index([instructorId])
}

model Assignment {
  id            String           @id @default(cuid())
  courseId      String
  title         String
  instructions  String?
  status        AssignmentStatus @default(DRAFT)
  dueAt         DateTime?
  maxScore      Int?
  attachmentUrl String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  archivedAt    DateTime?

  course      Course                 @relation(fields: [courseId], references: [id])
  submissions AssignmentSubmission[]

  @@index([courseId])
  @@index([status])
  @@index([dueAt])
}

model AssignmentSubmission {
  id            String                     @id @default(cuid())
  assignmentId  String
  userId        String
  content       String?
  attachmentUrl String?
  status        AssignmentSubmissionStatus @default(SUBMITTED)
  submittedAt   DateTime                   @default(now())
  isLate        Boolean                    @default(false)
  gradedAt      DateTime?
  score         Int?
  feedback      String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
  @@index([status])
}

model Exam {
  id              String     @id @default(cuid())
  courseId        String
  title           String
  description     String?
  status          ExamStatus @default(DRAFT)
  durationMinutes Int?
  passingScore    Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  archivedAt      DateTime?

  course    Course         @relation(fields: [courseId], references: [id])
  questions ExamQuestion[]
  attempts  ExamAttempt[]

  @@index([courseId])
  @@index([status])
}

model ExamQuestion {
  id             String           @id @default(cuid())
  examId         String
  type           ExamQuestionType
  prompt         String
  options        Json?
  correctAnswers Json?
  explanation    String?
  points         Int              @default(1)
  sortOrder      Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  exam    Exam         @relation(fields: [examId], references: [id])
  answers ExamAnswer[]

  @@unique([examId, sortOrder])
  @@index([examId])
  @@index([type])
}

model ExamAttempt {
  id            String            @id @default(cuid())
  examId        String
  userId        String
  status        ExamAttemptStatus @default(IN_PROGRESS)
  attemptNumber Int
  startedAt     DateTime          @default(now())
  submittedAt   DateTime?
  gradedAt      DateTime?
  score         Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  exam    Exam         @relation(fields: [examId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  answers ExamAnswer[]

  @@unique([userId, examId, attemptNumber])
  @@index([examId])
  @@index([userId])
  @@index([status])
}

model ExamAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId String
  answer     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attempt  ExamAttempt  @relation(fields: [attemptId], references: [id])
  question ExamQuestion @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

model Lesson {
  id          String            @id @default(cuid())
  courseId    String
  title       String
  contentType LessonContentType
  content     String
  sortOrder   Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  course   Course           @relation(fields: [courseId], references: [id])
  progress LessonProgress[]

  @@unique([courseId, sortOrder])
  @@index([courseId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  isCompleted Boolean  @default(true)
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}
