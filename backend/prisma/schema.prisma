generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

enum UserRole {
  USER
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  LOCKED
}

enum LearningPathStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CoursePaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MOCK
}

enum LessonContentType {
  VIDEO
  TEXT
  RESOURCE
  QUIZ
  LIVE_SESSION
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  FREE_TEXT
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum ExamAttemptEventType {
  TAB_HIDDEN
  TAB_VISIBLE
  WINDOW_BLUR
  WINDOW_FOCUS
  RECONNECT
  TIMER_EXPIRED
  MANUAL_SUBMIT
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssignmentSubmissionStatus {
  SUBMITTED
  GRADED
}

enum NotificationType {
  ENROLLMENT_SUCCESS
  ASSIGNMENT_GRADED
  CERTIFICATE_ISSUED
  COURSE_PUBLISHED
  SYSTEM
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

model User {
  id        String     @id
  email     String     @unique
  role      UserRole   @default(USER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  createdCourses         Course[]                @relation("CourseInstructor")
  lockedCourses          Course[]                @relation("CourseLockedBy")
  enrollments            Enrollment[]
  lessonProgress         LessonProgress[]
  auditLogs              AuditLog[]              @relation("AuditActor")
  courseReviews             CourseReview[]
  courseDiscussionComments  CourseDiscussionComment[]
  examAttempts              ExamAttempt[]
  assignmentSubmissions  AssignmentSubmission[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  certificates           Certificate[]
  learningPathsCreated   LearningPath[]   @relation("LearningPathCreator")
  coursePayments         CoursePayment[]
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  inAppEnabled      Boolean  @default(true)
  emailEnabled      Boolean  @default(false)
  enrollmentSuccess Boolean  @default(true)
  assignmentGraded  Boolean  @default(true)
  certificateIssued Boolean  @default(true)
  coursePublished   Boolean  @default(true)
  system            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id               String            @id @default(cuid())
  userId           String
  courseId         String
  verificationCode String            @unique
  status           CertificateStatus @default(ACTIVE)
  issuedAt         DateTime          @default(now())
  revokedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model Course {
  id              String       @id @default(cuid())
  title           String
  description     String?
  category        String?
  level           String?
  language        String?
  durationMinutes Int?
  requirements    String?
  outcomes        String?
  coverImageUrl   String?
  ratingAverage   Float        @default(0)
  ratingCount     Int          @default(0)
  priceCents      Int          @default(0)
  currency        String       @default("USD")
  status          CourseStatus @default(DRAFT)
  instructorId    String
  lockReason      String?
  lockedAt        DateTime?
  lockedById      String?
  statusBeforeLock CourseStatus?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  archivedAt      DateTime?

  instructor   User           @relation("CourseInstructor", fields: [instructorId], references: [id])
  lockedBy     User?          @relation("CourseLockedBy", fields: [lockedById], references: [id])
  lessons      Lesson[]
  exams        Exam[]
  enrollments  Enrollment[]
  reviews             CourseReview[]
  discussionComments  CourseDiscussionComment[]
  assignments         Assignment[]
  certificates Certificate[]
  learningPathCourses LearningPathCourse[]
  coursePayments      CoursePayment[]

  @@index([status])
  @@index([instructorId])
}

model Assignment {
  id            String           @id @default(cuid())
  courseId      String
  title         String
  instructions  String?
  status        AssignmentStatus @default(DRAFT)
  dueAt         DateTime?
  maxScore      Int?
  attachmentUrl String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  archivedAt    DateTime?

  course         Course                      @relation(fields: [courseId], references: [id])
  submissions    AssignmentSubmission[]
  rubricCriteria AssignmentRubricCriterion[]

  @@index([courseId])
  @@index([status])
  @@index([dueAt])
}

model AssignmentRubricCriterion {
  id           String   @id @default(cuid())
  assignmentId String
  title        String
  description  String?
  maxPoints    Int
  sortOrder    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment              @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scores     AssignmentRubricScore[]

  @@unique([assignmentId, sortOrder])
  @@index([assignmentId])
}

model AssignmentSubmission {
  id            String                     @id @default(cuid())
  assignmentId  String
  userId        String
  content       String?
  attachmentUrl String?
  status        AssignmentSubmissionStatus @default(SUBMITTED)
  submittedAt   DateTime                   @default(now())
  isLate        Boolean                    @default(false)
  gradedAt      DateTime?
  score         Int?
  feedback      String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  assignment   Assignment              @relation(fields: [assignmentId], references: [id])
  user         User                    @relation(fields: [userId], references: [id])
  rubricScores AssignmentRubricScore[]

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
  @@index([status])
}

model AssignmentRubricScore {
  id           String   @id @default(cuid())
  submissionId String
  criterionId  String
  points       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission AssignmentSubmission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  criterion  AssignmentRubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, criterionId])
  @@index([submissionId])
  @@index([criterionId])
}

model Exam {
  id              String     @id @default(cuid())
  courseId        String
  title           String
  description     String?
  status          ExamStatus @default(DRAFT)
  durationMinutes Int?
  passingScore    Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  archivedAt      DateTime?

  course    Course         @relation(fields: [courseId], references: [id])
  questions ExamQuestion[]
  attempts  ExamAttempt[]

  @@index([courseId])
  @@index([status])
}

model ExamQuestion {
  id             String           @id @default(cuid())
  examId         String
  type           ExamQuestionType
  prompt         String
  options        Json?
  correctAnswers Json?
  explanation    String?
  points         Int              @default(1)
  sortOrder      Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  exam    Exam         @relation(fields: [examId], references: [id])
  answers ExamAnswer[]

  @@unique([examId, sortOrder])
  @@index([examId])
  @@index([type])
}

model ExamAttempt {
  id            String            @id @default(cuid())
  examId        String
  userId        String
  status        ExamAttemptStatus @default(IN_PROGRESS)
  attemptNumber Int
  startedAt     DateTime          @default(now())
  submittedAt   DateTime?
  gradedAt      DateTime?
  score         Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  exam             Exam                        @relation(fields: [examId], references: [id])
  user             User                        @relation(fields: [userId], references: [id])
  answers          ExamAnswer[]
  integrityEvents  ExamAttemptIntegrityEvent[]

  @@unique([userId, examId, attemptNumber])
  @@index([examId])
  @@index([userId])
  @@index([status])
}

model ExamAttemptIntegrityEvent {
  id            String               @id @default(cuid())
  attemptId     String
  type          ExamAttemptEventType
  clientEventId String?
  metadata      Json?
  createdAt     DateTime             @default(now())

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, clientEventId])
  @@index([attemptId])
  @@index([attemptId, type])
}

model ExamAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId String
  answer     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attempt  ExamAttempt  @relation(fields: [attemptId], references: [id])
  question ExamQuestion @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

model CourseDiscussionComment {
  id        String   @id @default(cuid())
  courseId  String
  lessonId  String?
  userId    String
  parentId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson   Lesson?                   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  parent   CourseDiscussionComment?  @relation("DiscussionReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  CourseDiscussionComment[] @relation("DiscussionReplies")

  @@index([courseId, lessonId])
  @@index([parentId])
  @@index([userId])
}

model Lesson {
  id                   String            @id @default(cuid())
  courseId             String
  title                String
  contentType          LessonContentType
  content              String
  sortOrder            Int
  prerequisiteLessonId String?
  archivedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  course             Course           @relation(fields: [courseId], references: [id])
  prerequisiteLesson Lesson?          @relation("LessonPrerequisite", fields: [prerequisiteLessonId], references: [id], onDelete: SetNull)
  dependentLessons   Lesson[]         @relation("LessonPrerequisite")
  progress           LessonProgress[]
  discussionComments CourseDiscussionComment[]

  @@unique([courseId, sortOrder])
  @@index([courseId])
  @@index([prerequisiteLessonId])
  @@index([courseId, archivedAt])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

model LessonProgress {
  id                   String   @id @default(cuid())
  userId               String
  lessonId             String
  isCompleted          Boolean  @default(true)
  watchPositionSeconds Int      @default(0)
  completedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model LearningPath {
  id            String             @id @default(cuid())
  title         String
  description   String?
  coverImageUrl String?
  status        LearningPathStatus @default(DRAFT)
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  archivedAt    DateTime?

  createdBy User                 @relation("LearningPathCreator", fields: [createdById], references: [id])
  courses   LearningPathCourse[]

  @@index([status])
  @@index([createdById])
}

model LearningPathCourse {
  id             String @id @default(cuid())
  learningPathId String
  courseId       String
  sortOrder      Int

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId])
  @@unique([learningPathId, sortOrder])
  @@index([courseId])
}

model CoursePayment {
  id             String              @id @default(cuid())
  userId         String
  courseId       String
  amountCents    Int
  currency       String              @default("USD")
  status         CoursePaymentStatus @default(PENDING)
  provider       PaymentProvider     @default(MOCK)
  providerRef    String?
  idempotencyKey String
  createdAt      DateTime            @default(now())
  completedAt    DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, courseId])
  @@index([courseId])
  @@index([status])
}
