generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id
  email     String   @unique
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
