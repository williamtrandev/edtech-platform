NODE_ENV=development
PORT=4000
LOG_LEVEL=info

SUPABASE_DB_URL=
SUPABASE_DIRECT_URL=
SUPABASE_JWT_SECRET=
SUPABASE_URL=

REDIS_URL=redis://127.0.0.1:6379

# Public URL for links in notification emails (course learn, certificates, etc.)
APP_PUBLIC_URL=http://localhost:5173

# Email: LOG (dev console), SMTP (production), or RESEND (HTTP API)
EMAIL_PROVIDER=LOG
EMAIL_FROM=EdTech Platform <noreply@example.com>

# Required when EMAIL_PROVIDER=SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Required when EMAIL_PROVIDER=RESEND
RESEND_API_KEY=
